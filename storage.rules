rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Presupuestos: lectura pública (links compartibles), escritura solo auth.
    match /presupuestos/{fileName=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Plantillas de consentimientos: lectura pública (paciente las ve via link
    // de consentRequests), escritura solo auth (admin sube).
    match /consentTemplates/{fileName=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Vouchers de pago e imágenes internas: solo auth
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
